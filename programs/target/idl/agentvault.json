{
  "version": "0.1.0",
  "name": "agentvault",
  "address": "JCDFEsY5Jq22vJRsUiKY6X4xxKmmavwtdiD4unaQridp",
  "metadata": {
    "name": "agentvault",
    "version": "0.1.0",
    "spec": "0.1.0",
    "description": "AgentVault — autonomous agent deposit/withdraw protocol for AI agents on Solana"
  },
  "instructions": [
    {
      "name": "initializeVault",
      "docs": ["Called once per agent to create their vault account on-chain"],
      "accounts": [
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false,
          "pda": {
            "seeds": [
              { "kind": "const", "type": "bytes", "value": [118, 97, 117, 108, 116] },
              { "kind": "account", "type": "publicKey", "path": "owner" }
            ]
          }
        },
        { "name": "owner", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": []
    },
    {
      "name": "deposit",
      "docs": ["Agent deposits lamports into their vault"],
      "accounts": [
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false,
          "pda": {
            "seeds": [
              { "kind": "const", "type": "bytes", "value": [118, 97, 117, 108, 116] },
              { "kind": "account", "type": "publicKey", "path": "owner" }
            ]
          }
        },
        { "name": "owner", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "amount", "type": "u64" }
      ]
    },
    {
      "name": "withdraw",
      "docs": ["Agent withdraws lamports from their vault back to their wallet"],
      "accounts": [
        {
          "name": "vault",
          "isMut": true,
          "isSigner": false,
          "pda": {
            "seeds": [
              { "kind": "const", "type": "bytes", "value": [118, 97, 117, 108, 116] },
              { "kind": "account", "type": "publicKey", "path": "owner" }
            ]
          }
        },
        { "name": "owner", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "amount", "type": "u64" }
      ]
    }
  ],
  "accounts": [
    {
      "name": "VaultState",
      "docs": ["On-chain vault state for each agent"],
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "owner",          "type": "publicKey", "docs": ["Agent wallet address"] },
          { "name": "totalDeposited", "type": "u64",       "docs": ["Lifetime deposits in lamports"] },
          { "name": "totalWithdrawn", "type": "u64",       "docs": ["Lifetime withdrawals in lamports"] },
          { "name": "depositCount",   "type": "u32",       "docs": ["Number of deposits"] },
          { "name": "withdrawCount",  "type": "u32",       "docs": ["Number of withdrawals"] },
          { "name": "bump",           "type": "u8",        "docs": ["PDA bump seed"] }
        ]
      }
    }
  ],
  "errors": [
    { "code": 6000, "name": "ZeroAmount",        "msg": "Amount must be greater than zero" },
    { "code": 6001, "name": "InsufficientFunds", "msg": "Insufficient funds — vault must remain rent-exempt" },
    { "code": 6002, "name": "Overflow",          "msg": "Arithmetic overflow" }
  ]
}